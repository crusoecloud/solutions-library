# Grafana datasource Secret template.
#
# The k8s-sidecar watches Secrets with label grafana_datasource="1" and writes
# the data values as files to /etc/grafana/provisioning/datasources/ inside
# the Grafana pod. Grafana then loads those files at startup or on live-reload.
#
# Using a Secret (not a ConfigMap) keeps the bearer token in Kubernetes' encrypted
# secret store. Grafana reads the file content as-is, so the token must be
# embedded literally — NOT as a ${VAR} placeholder.
#
# Apply with envsubst so the shell expands the placeholders before they reach
# Kubernetes (see README Step 3):
#
#   MONITORING_TOKEN=<your-token> PROJECT_ID=<your-project-id> \
#     envsubst < manifests/grafana-datasource-secret.yaml.example | kubectl apply -f -
#
# Add this file to .gitignore if you generate a filled-in copy:
#   manifests/grafana-datasource-secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: crusoe-datasource
  namespace: monitoring
  labels:
    grafana_datasource: "1"
stringData:
  crusoe-telemetry.yaml: |
    apiVersion: 1
    datasources:
      - name: Crusoe Telemetry Relay
        type: prometheus
        uid: crusoe-telemetry
        access: proxy
        url: https://api.crusoecloud.com/v1alpha5/projects/${PROJECT_ID}/metrics/timeseries
        isDefault: true
        jsonData:
          httpMethod: GET
          timeInterval: "60s"
          httpHeaderName1: "Authorization"
        secureJsonData:
          httpHeaderValue1: "Bearer ${MONITORING_TOKEN}"
        editable: true
