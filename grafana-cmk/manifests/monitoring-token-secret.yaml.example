# Copy this file to monitoring-token-secret.yaml and fill in your values.
#
#   cp manifests/monitoring-token-secret.yaml.example manifests/monitoring-token-secret.yaml
#
# monitoring-token-secret.yaml is listed in .gitignore — do NOT commit the real file.
#
# To generate a monitoring token:
#   crusoe monitoring tokens create
#
# To find your project ID:
#   crusoe projects list
#
# Paste the raw values below — stringData handles encoding automatically.
apiVersion: v1
kind: Secret
metadata:
  name: crusoe-monitoring-token
  namespace: monitoring
type: Opaque
stringData:
  MONITORING_TOKEN: "<your-monitoring-token>"
  PROJECT_ID: "<your-project-id>"
