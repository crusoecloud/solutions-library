            "uid": "crusoe-metrics"
          },
          "expr": "sum(increase(DCGM_FI_DEV_PCIE_REPLAY_COUNTER{cluster_id=~\"$cluster\"}[24h])) or vector(0)",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ]
    },
