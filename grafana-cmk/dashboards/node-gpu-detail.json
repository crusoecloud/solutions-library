          "datasource": {
            "type": "prometheus",
            "uid": "crusoe-metrics"
          },
          "expr": "100 * avg by (mode) (rate(crusoe_vm_cpu_seconds_total{vm_name=\"$node\", mode!=\"idle\"}[$__rate_interval]))",
