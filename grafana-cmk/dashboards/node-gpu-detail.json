    {
      "id": 7,
      "type": "stat",
      "title": "CPU Used %",
      "description": "Percentage of total CPU capacity in use right now (1 - average idle fraction across all logical CPUs).",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-metrics"
      },
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "crusoe-metrics"
          },
          "expr": "100 * (1 - avg(rate(crusoe_vm_cpu_seconds_total{vm_name=\"$node\", mode=\"idle\"}[$__rate_interval])))",
