    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Utilization by Mode",
      "description": "Stacked CPU utilization by mode (user, system, io_wait, nice). Sum of all modes equals total CPU busy %. Useful for diagnosing iowait spikes vs straight compute load.",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-metrics"
      },
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 10
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 30,
            "lineInterpolation": "linear",
