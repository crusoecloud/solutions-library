    {
      "id": 4,
      "type": "stat",
      "title": "Lifetime TX (counter)",
      "description": "Total bytes transmitted over the lifetime of the underlying counter.",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-metrics"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
