          "legendFormat": "{{vm_name}} {{hca_number}}"
        }
      ],
      "interval": "5m"
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "RX Errors (per HCA)",
      "description": "Per-HCA RX error rate (events/sec).",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-metrics"
      },
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
