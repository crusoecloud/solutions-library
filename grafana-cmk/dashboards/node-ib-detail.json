{
  "uid": "crusoe-ib-node",
  "title": "Crusoe \u2014 InfiniBand Node View",
  "tags": [
    "crusoe",
    "infiniband",
    "node"
  ],
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "crusoe-telemetry"
        },
        "query": "label_values(crusoe_ib_port_throughput_rx, cluster_id)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "crusoe-telemetry"
        },
        "query": "label_values(crusoe_ib_port_throughput_rx{cluster_id=~\"$cluster\"}, vm_name)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Selected Nodes RX",
      "description": "Total RX bandwidth across selected nodes",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-telemetry"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "crusoe-telemetry"
          },
          "expr": "sum(rate(crusoe_ib_port_throughput_rx{cluster_id=~\"$cluster\", vm_name=~\"$node\"}[$__rate_interval])) / 8",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Selected Nodes TX",
      "description": "Total TX bandwidth across selected nodes",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-telemetry"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "crusoe-telemetry"
          },
          "expr": "sum(rate(crusoe_ib_port_throughput_tx{cluster_id=~\"$cluster\", vm_name=~\"$node\"}[$__rate_interval])) / 8",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RX Errors",
      "description": "Total RX errors across selected nodes",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-telemetry"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "crusoe-telemetry"
          },
          "expr": "sum(increase(crusoe_ib_port_error_rx{cluster_id=~\"$cluster\", vm_name=~\"$node\"}[$__rate_interval]))",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Link Integrity Errors",
      "description": "Local link integrity errors across selected nodes",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-telemetry"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
