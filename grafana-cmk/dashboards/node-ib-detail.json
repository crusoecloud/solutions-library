          },
          "expr": "rate(crusoe_ib_port_error_rx{cluster_id=~\"$cluster\", vm_name=~\"$node\"}[10m])",
          "legendFormat": "{{vm_name}} {{hca_number}}"
        }
      ],
      "interval": "5m"
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "TX Wait / Back-pressure (per HCA)",
      "description": "Per-HCA TX-wait rate \u2014 indicates congestion or flow control.",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-metrics"
      },
      "gridPos": {
        "x": 12,
        "y": 36,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
