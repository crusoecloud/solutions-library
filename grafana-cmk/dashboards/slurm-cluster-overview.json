        {
          "datasource": {
            "type": "prometheus",
            "uid": "crusoe-metrics"
          },
          "expr": "sum(crusoe_slurm_nodes_alloc{cluster_id=~\"$cluster\"})",
          "instant": true,
          "legendFormat": "__auto"
        }
