    {
      "id": 17,
      "type": "timeseries",
      "title": "RX Bandwidth Utilization % (per node)",
      "description": "Per-node RX utilization as % of total line rate. Note: line_rate's gig_bit_per_sec label reports 128 on HCAs whose ibstat is 400 (NDR), so the denominator is off by ~3\u00d7. Treat as relative.",
      "datasource": {
        "type": "prometheus",
        "uid": "crusoe-metrics"
      },
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 12,
        "h": 8
