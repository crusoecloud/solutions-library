    {
      "id": 8,
      "type": "stat",
      "title": "Hottest GPU Right Now",
      "description": "Maximum GPU die temperature across every GPU in the selected cluster right now. Green <70\u00b0C, yellow 70-80\u00b0C, red \u226580\u00b0C.",
